{
  "name": "bibtex-root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "bun --cwd=packages/stringify run build",
    "build:all": "bun --filter=\"*\" run build",
    "publish:stringify": "cd packages/stringify && npm publish --access public"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/bun": "^1.3.14"
  }
}